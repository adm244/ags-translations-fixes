managed struct Mapping {
    char c;
    short x;
    short y;
    short w;
    short h;
};

// NOTE: cannot directly create an array of managed struct;
//  also cannot return non-managed struct from function
struct MappingWrapper {
    Mapping* mapping;
};

// 18344 - our new font sprite
// 15334 - original font sprite
int newfont = 18344;
#define MAPPINGS_SIZE_MAX 256
MappingWrapper mappings[];

bool IsWhitespace(char c)
{
    switch (c) {
        case 9:
        case 32:
            return true;
        default:
            return false;
    }
}

String Trim(String str)
{
    if (str == null) {
        return null;
    }

    int start = 0;
    while (start < str.Length && IsWhitespace(str.Chars[start])) {
        start = start + 1;
    }

    int end = str.Length;
    while (end > 0 && IsWhitespace(str.Chars[end - 1])) {
        end = end - 1;
    }

    return str.Substring(start, end - start);
}

Dictionary* ParseEncodingsFile(String filepath)
{
    Dictionary* encodings = Dictionary.Create(eNonSorted, eCaseInsensitive);
    if (encodings == null) {
        return null;
    }

    File *input = File.Open(filepath, eFileRead);
    if (input == null) {
        return null;
    }

    while (!input.EOF) {
        String line = Trim(input.ReadRawLineBack());
        if (line == null || line.Length < 3 || line.StartsWith("##")) {
            continue;
        }

        int splitPos = line.IndexOf("=");
        if (splitPos < 1) {
            continue;
        }

        line = line.ReplaceCharAt(splitPos, ' ');
        String key = Trim(line.Substring(0, splitPos));
        String value = Trim(line.Substring(splitPos, line.Length - splitPos));
        if (String.IsNullOrEmpty(key) || String.IsNullOrEmpty(value)) {
            continue;
        }

        encodings.Set(key.LowerCase(), value.LowerCase());
    }

    input.Close();
    return encodings;
}

bool ReadCharMapping(String filepath)
{
    File* input = File.Open(filepath, eFileRead);
    if (input == null) {
        return false;
    }

    int mappings_count = 0;
    mappings = new MappingWrapper[MAPPINGS_SIZE_MAX];

    while (!input.EOF && mappings_count < MAPPINGS_SIZE_MAX - 1) {
        String line = Trim(input.ReadRawLineBack());
        if (line == null || line.Length < 10 || line.StartsWith("##")) {
            continue;
        }

        String parts[] = new String[5];
        parts[0] = line.Substring(0, 2);
        line = line.Substring(3, line.Length - 3);
        for (int i = 1; i < 4; i++) {
            int index = line.IndexOf(",");
            if (index < 0) {
                break;
            }
            parts[i] = line.Substring(0, index);
            line = line.ReplaceCharAt(index, ' ');
            line = line.Substring(index, line.Length - index);
        }
        parts[4] = line;

        if (parts[0].Chars[0] != ':' || parts[0].Length != 2) {
            continue;
        }

        bool invalid = false;
        for (int i = 1; i < 5; i++) {
            parts[i] = Trim(parts[i]);
            if (String.IsNullOrEmpty(parts[i])) {
                invalid = true;
                break;
            }
        }

        if (invalid) {
            continue;
        }

        Mapping* mapping = new Mapping;
        mapping.c = parts[0].Chars[1];
        mapping.x = parts[1].AsInt;
        mapping.y = parts[2].AsInt;
        mapping.w = parts[3].AsInt;
        mapping.h = parts[4].AsInt;

        mappings[mappings_count].mapping = mapping;
        mappings_count = mappings_count + 1;
    }

    input.Close();

    // NOTE: don't trust AGS to initialize it to null
    mappings[mappings_count].mapping = null;
    return mappings_count > 0;
}

function SetupVariableFont(int fontNum, int sprite, int spacing)
{
    // NOTE: there's no need to call 'SetSpriteFont' since we're using variable width font
    SetVariableSpriteFont(fontNum, sprite);
    SetSpacing(fontNum, spacing);

    for (int i = 0; i < MAPPINGS_SIZE_MAX; i++) {
        Mapping* mapping = mappings[i].mapping;
        if (mapping == null) {
            break;
        }
        SetGlyph(fontNum, mapping.c, mapping.x, mapping.y, mapping.w, mapping.h);
    }
}

function Test()
{
    if (IsTranslationAvailable()) {
        Dictionary* encodings = ParseEncodingsFile("$INSTALLDIR$/encoding.txt");
        if (encodings != null) {
            String encoding = encodings.Get(Game.TranslationFilename.LowerCase());
            if (!String.IsNullOrEmpty(encoding)) {
                String filepath = String.Format("$INSTALLDIR$/encodings/%s.txt", encoding);
                if (ReadCharMapping(filepath)) {
                    SetupVariableFont(9, newfont, 1);
                    SetupVariableFont(13, newfont, 1);
                    SetupVariableFont(14, newfont, 1);
                    return;
                }
            }
        }
    }

    Display("Original code here");
}
